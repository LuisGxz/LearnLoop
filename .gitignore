# Root ignores for the LearnLoop monorepo (backend/ + frontend/ also have their own)

# Java / Maven
backend/target/
*.class

# Node / Angular
frontend/node_modules/
frontend/dist/
frontend/.angular/

# Playwright (E2E artifacts; committed screenshots live in frontend/docs/screenshots)
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/.playwright/

# Secrets / env
.env
.env.*
*.local
.azure-secrets.local

# OS / IDE
.DS_Store
.idea/
*.iml
